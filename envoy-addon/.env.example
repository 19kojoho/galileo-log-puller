# envoy-addon — copy to .env and fill in.
#
# The shim uses these to call Protect and to write traces to your Galileo
# project. The addon itself makes no assumptions about which cluster you
# use (self-hosted, dedicated, or SaaS) — the URL you set here decides.

# --- Your Galileo cluster ---
# API base, not the browser console URL.
#   self-hosted:     https://api.<your-cluster>.galileocloud.io
#   dedicated:       https://api.<your-tenant>.galileocloud.io
#   Galileo SaaS:    https://api.galileo.ai
GALILEO_CONSOLE_URL=

# --- Credentials ---
# API key that has permission to call invoke_protect on the target project
# AND to write traces to the target log stream.
GALILEO_API_KEY=

# --- Where to write ---
# Both must already exist in your project. The stage must be StageType.central
# for its verdicts to be browsable in the console (StageType.local won't
# render). Create with galileo.stages.create_protect_stage() if needed.
GALILEO_PROJECT=
GALILEO_STAGE=poc-protect-stage
GALILEO_LOG_STREAM=production

# --- Guardrail posture ---
# Fail-closed by default (regulated workloads). Set to true to demo
# fail-open behavior at the shim level.
FAIL_OPEN=false

# Total time budget per Protect call (seconds). Must be less than Envoy's
# ext_proc message_timeout (10s in envoy.yaml) so the shim has time to
# return a clean ImmediateResponse before Envoy gives up on the stream.
PROTECT_TIMEOUT_S=8

# --- Upstream (what Envoy forwards to on ALLOW) ---
# Docker-compose service name + port. mock-llm is the bundled default for
# smoke-testing. Point at your own agent's HTTP endpoint in production.
#
#   Bundled sanity check:      http://mock-llm:8000
#   Your agent on the host:    http://host.docker.internal:8000
#   Your agent in the network: http://<service-name>:<port>
UPSTREAM_URL=http://mock-llm:8000
